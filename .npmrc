# .npmrc - NPM設定ファイル

# パッケージ整合性チェックをスキップ
unsafe-perm = true

# onnxruntime ダウンロードをスキップ
onnxruntime_skip_download = true

# 整合性チェックを緩和
strict-ssl = false

# レジストリからの整合性チェックをスキップ
audit = false

# 壊れたパッケージを許可
fetch-retries = 5
fetch-retry-factor = 2
fetch-retry-mintimeout = 20000
fetch-retry-maxtimeout = 120000
