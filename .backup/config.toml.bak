# supabase/config.toml
# Supabase CLI設定ファイル
# 作成日: 2025/5/7

# プロジェクト設定
[project]
# プロジェクト参照ID
id = "wqhkevngqjipjohshble"

# APIエンドポイント設定
[api]
# ローカル開発用のエンドポイント
local_endpoint = "http://localhost:54321"
# 本番環境用のエンドポイント
prod_endpoint = "https://wqhkevngqjipjohshble.supabase.co"

# データベース設定
[db]
# ローカル開発用の接続情報
port = 54322
shadow_port = 54320
major_version = 15

# ローカル開発用の認証情報
[db.auth]
username = "postgres"
password = "postgres"

# スタジオ設定
[studio]
port = 54323

# インフラストラクチャ設定
[inbucket]
port = 54324
smtp_port = 54325
pop3_port = 54326

# 認証設定
[auth]
site_url = "http://localhost:3000"
additional_redirect_urls = ["https://localhost:3000"]
jwt_expiry = 3600
enable_signup = true

# ストレージ設定
[storage]
file_size_limit = "50MiB"